{
  "name": "babylon-catalog-ui",
  "version": "0.0.2",
  "description": "An open source build scaffolding utility for web apps.",
  "repository": "https://github.com/redhat-cop/babylon.git",
  "homepage": "https://github.com/redhat-cop/babylon",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "prebuild": "if test \"$KEEP_ASSETS\" != \"true\" ; then pnpm run clean ; fi ",
    "dr:surge": "node dr-surge.js",
    "build": "webpack --config webpack.prod.js && pnpm run dr:surge",
    "start": "sirv dist --cors --single --host --port 8080",
    "start:dev": "webpack serve --color --progress --config webpack.dev.js",
    "test": "jest",
    "eslint": "eslint ./src/",
    "lint": "pnpm run eslint",
    "format": "prettier --check --write \"./**/*.{tsx,ts,json,css,js}\"",
    "type-check": "tsc --noEmit",
    "ci-checks": "pnpm run type-check && pnpm run lint && pnpm run test",
    "build:bundle-profile": "webpack --config webpack.prod.js --profile --json > stats.json",
    "bundle-profile:analyze": "pnpm run build:bundle-profile && webpack-bundle-analyzer ./stats.json",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/json2csv": "^5.0.3",
    "@types/lodash.throttle": "^4.1.9",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "babel-core": "^6.26.3",
    "babel-loader": "^10.1.1",
    "babel-plugin-transform-imports": "^2.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.11.0",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "dotenv-webpack": "^9.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "file-loader": "^6.2.0",
    "globals": "^17.6.0",
    "history": "^5.3.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-fetch-mock": "^3.0.3",
    "mini-css-extract-plugin": "^2.10.1",
    "postcss": "^8.5.15",
    "postcss-custom-media": "^8.0.2",
    "postcss-loader": "^7.3.4",
    "prettier": "^3.8.3",
    "prop-types": "^15.6.1",
    "raw-loader": "^4.0.2",
    "rimraf": "^6.1.3",
    "sirv-cli": "^3.0.1",
    "style-loader": "^3.3.4",
    "svg-url-loader": "^8.0.0",
    "terser-webpack-plugin": "^5.6.1",
    "ts-jest": "^29.4.11",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "url-loader": "^4.1.1",
    "webpack": "^5.107.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.4",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@lexical/code": "^0.44.0",
    "@lexical/html": "^0.44.0",
    "@lexical/link": "^0.44.0",
    "@lexical/list": "^0.44.0",
    "@lexical/markdown": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@lexical/table": "^0.44.0",
    "@lexical/utils": "^0.44.0",
    "@monaco-editor/react": "^4.7.0",
    "@patternfly/react-core": "^6.5.1",
    "@patternfly/react-drag-drop": "^6.5.1",
    "@patternfly/react-icons": "^6.5.1",
    "@patternfly/react-styles": "^6.5.1",
    "@patternfly/react-table": "^6.5.1",
    "@reduxjs/toolkit": "^2.0.0",
    "asciidoctor": "^3.0.2",
    "dompurify": "^3.4.5",
    "fuse.js": "^7.3.0",
    "js-yaml": "^4.2.0",
    "json2csv": "^5.0.7",
    "lexical": "^0.44.0",
    "lodash.throttle": "^4.1.1",
    "moment": "^2.30.1",
    "monaco-editor": "^0.55.1",
    "parse-duration": "^1.1.1",
    "react": "^18.2.0",
    "react-big-calendar": "^1.20.0",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-redux": "^9.0.0",
    "react-router-dom": "^6.28.0",
    "react-window": "^1.8.11",
    "swr": "^2.4.1",
    "yjs": "^13.6.30"
  }
}
